# Creator Hub Agent OS environment template
# Placeholder values only. Do not put real secrets in this file.

# Browser-exposed Vite variables
# Any variable starting with VITE_ can be included in the browser bundle.
VITE_APP_ENV=
VITE_APP_BASE_URL=

# Server-side AI provider secrets
# Never prefix API keys with VITE_.
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# Server-side OAuth credentials
# Client secrets must never be exposed to the browser.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server-side GitHub automation credentials
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# Server-side Cloudflare deployment credentials
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
CLOUDFLARE_API_TOKEN=
